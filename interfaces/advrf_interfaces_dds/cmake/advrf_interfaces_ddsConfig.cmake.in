@PACKAGE_INIT@
include(CMakeFindDependencyMacro)

set(advrf_interfaces_dds_USE_FASTDDS @USE_FASTDDS@)

if(advrf_interfaces_dds_USE_FASTDDS)
    find_dependency(fastcdr 2)
    find_dependency(fastdds 3)
else()
    find_dependency(CycloneDDS)
    find_dependency(CycloneDDS-CXX)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/advrf_interfaces_ddsTargets.cmake")
check_required_components(advrf_interfaces_dds)