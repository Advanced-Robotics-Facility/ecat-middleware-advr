@PACKAGE_INIT@

set(_ECAT_MASTER_FUTURE_PREFIX "${PACKAGE_PREFIX_DIR}")

include(CMakeFindDependencyMacro)

find_dependency(advrf_interfaces_protobuf)
find_dependency(advrf_middleware_core)

set(PACKAGE_PREFIX_DIR "${_ECAT_MASTER_FUTURE_PREFIX}")
unset(_ECAT_MASTER_FUTURE_PREFIX)

include("${CMAKE_CURRENT_LIST_DIR}/ecat_master_futureTargets.cmake")

check_required_components(ecat_master_future)

set(ecat_master_future_SHARE_DIR
    "${PACKAGE_PREFIX_DIR}/share/ecat_master_future")

set(ecat_master_future_CONFIG_DIR
    "${ecat_master_future_SHARE_DIR}/config")